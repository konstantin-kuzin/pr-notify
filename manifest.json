{
  "manifest_version": 3,
  "name": "PR Notify",
  "description": "Показывает pull requests из блока Assigned to my teams в Azure DevOps",
  "version": "1.4",
  "minimum_chrome_version": "116",
  "permissions": [
    "alarms",
    "storage",
    "notifications",
    "scripting"
  ],
  "host_permissions": [
    "https://hqrndtfs.avp.ru/*"
  ],
  "background": {
    "service_worker": "background.mjs",
    "type": "module"
  },
  "action": {
    "default_title": "PR Notify",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
